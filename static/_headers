/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Never let the edge or browser serve a stale worker script: it gates every
# deploy, so it must always be revalidated against the origin. (no-cache means
# "may store, must revalidate" — not "never store".)
/service-worker.js
  Cache-Control: no-cache

# Content-hashed build assets are safe to cache forever: a content change yields
# a new filename, so the URL never serves stale bytes. Cloudflare Pages' default
# for static files is max-age=0/must-revalidate, so without this every hashed
# JS/WASM chunk is re-validated on each load. (Requires the zone Browser Cache
# TTL = "Respect Existing Headers", else Cloudflare overrides this.)
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable
