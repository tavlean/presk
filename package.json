{
  "private": true,
  "name": "sqush",
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://sqush.app",
  "license": "apache-2.0",
  "engines": {
    "node": ">=24.12.0 <25",
    "npm": ">=11"
  },
  "scripts": {
    "audit:static-output": "node scripts/audit-static-output.mjs",
    "build": "npm run sync && vite build",
    "check": "npm run format:check && npm run sync && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && npm run build && npm run audit:static-output",
    "audit": "npm audit --audit-level=low",
    "dev": "vite dev",
    "format": "prettier --write \"**/*.{js,css,json,ts,tsx,svelte}\"",
    "format:check": "prettier --check \"**/*.{js,css,json,ts,tsx,svelte}\"",
    "preview": "vite preview",
    "sync": "node scripts/sync-sveltekit-app.mjs",
    "test": "npm run check && npm run test:e2e",
    "test:e2e": "playwright test",
    "bench": "playwright test --config playwright.bench.config.ts",
    "bench:compare": "node benchmarks/compare.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.61.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "comlink": "^4.4.2",
    "pointer-tracker": "^2.5.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "5.55.9",
    "svelte-check": "4.3.4",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "wasm-feature-detect": "^1.8.0"
  },
  "overrides": {
    "cookie": "1.1.1"
  }
}
