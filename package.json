{
  "private": true,
  "name": "sqush",
  "version": "2.0.0",
  "homepage": "https://sqush.app",
  "license": "apache-2.0",
  "engines": {
    "node": ">=20.16.0 <21",
    "npm": ">=10"
  },
  "scripts": {
    "build": "rollup -c && node lib/move-output.js",
    "check": "npm run format:check && npm run build && npm run smoke:build && npm run test:helpers && npm run typecheck",
    "audit": "npm audit --audit-level=low",
    "debug": "node --inspect-brk node_modules/.bin/rollup -c",
    "dev": "node lib/dev-server.js",
    "format": "prettier --write \"**/*.{js,css,json,md,ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{js,css,json,md,ts,tsx}\"",
    "preview": "node lib/preview-server.js",
    "smoke:build": "node lib/smoke-build.js",
    "test": "npm run check",
    "test:bulk": "npm run test:helpers",
    "test:helpers": "node lib/test-helpers.js",
    "watch": "rollup -cw",
    "serve": "node lib/dev-static-server.js",
    "typecheck": "tsc -b",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^17.1.0",
    "@rollup/plugin-node-resolve": "^11.2.1",
    "@rollup/plugin-replace": "^2.4.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@surma/rollup-plugin-off-main-thread": "^2.2.3",
    "@types/dedent": "^0.7.2",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^16.18.126",
    "@web/rollup-plugin-import-meta-assets": "^1.0.8",
    "comlink": "^4.4.2",
    "cssnano": "^6.1.2",
    "dedent": "^0.7.0",
    "del": "^5.1.0",
    "file-drop-element": "^1.0.1",
    "husky": "^7.0.4",
    "idb-keyval": "^3.2.0",
    "image-size": "^0.9.7",
    "linkstate": "^2.0.1",
    "lint-staged": "^10.5.4",
    "lodash.camelcase": "^4.3.0",
    "mime-types": "^2.1.35",
    "pointer-tracker": "^2.5.3",
    "postcss": "^8.5.15",
    "postcss-modules": "^6.0.1",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "postcss-url": "^10.1.4",
    "preact": "^10.5.5",
    "preact-render-to-string": "^5.1.11",
    "prettier": "^2.8.8",
    "rollup": "^2.38.0",
    "serve": "^14.2.6",
    "typescript": "^4.9.5",
    "wasm-feature-detect": "^1.8.0"
  },
  "lint-staged": {
    "*.{js,css,json,md,ts,tsx}": "prettier --write",
    "*.{c,h,cpp,hpp}": "clang-format -i",
    "*.rs": "rustfmt"
  }
}
