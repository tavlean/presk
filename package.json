{
  "private": true,
  "name": "frisp",
  "version": "2.0.0",
  "type": "module",
  "homepage": "https://frisp.app",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.12.0 <25",
    "npm": ">=11"
  },
  "scripts": {
    "audit:static-output": "node scripts/audit-static-output.mjs",
    "build": "npm run sync && vite build",
    "typecheck": "npm run sync && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "npm run typecheck && vite build && npm run audit:static-output",
    "audit": "npm audit --audit-level=low",
    "dev": "vite dev",
    "format": "prettier --write \"**/*.{js,css,json,ts,tsx,svelte}\"",
    "format:check": "prettier --check \"**/*.{js,css,json,ts,tsx,svelte}\"",
    "prepare": "node scripts/install-git-hooks.mjs",
    "preview": "vite preview",
    "sync": "node scripts/patch-codec-wrappers.mjs",
    "test": "npm run check && npm run test:unit && PLAYWRIGHT_SKIP_BUILD=1 npm run test:e2e",
    "test:unit": "svelte-kit sync && vitest run",
    "test:e2e": "playwright test",
    "bench": "playwright test --config benchmarks/playwright.config.ts",
    "bench:compare": "node benchmarks/compare.mjs",
    "bench:svg": "node benchmarks/svg/run-frisp.mjs",
    "bench:svg:compare": "node benchmarks/svg/compare.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.61.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "^24.13.2",
    "client-zip": "^2.5.0",
    "comlink": "^4.4.2",
    "lint-staged": "^17.0.8",
    "pointer-tracker": "^2.5.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "simple-git-hooks": "^2.13.1",
    "svelte": "5.55.9",
    "svelte-check": "^4.6.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "^4.1.9",
    "wasm-feature-detect": "^1.8.0"
  },
  "overrides": {
    "cookie": "1.1.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,css,json,ts,tsx,svelte}": "prettier --write"
  },
  "prettier": {
    "endOfLine": "lf",
    "plugins": [
      "prettier-plugin-svelte"
    ],
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "pixelmatch": "^7.2.0",
    "svgo": "^4.0.1"
  }
}
